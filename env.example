# Supabase Configuration
# Get these values from your Supabase project settings: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Agora Configuration (for video calls)
# Get these values from your Agora project: https://console.agora.io/
EXPO_PUBLIC_AGORA_APP_ID=your_agora_app_id
EXPO_PUBLIC_AGORA_ENCRYPTION_KEY=your_agora_encryption_key
EXPO_PUBLIC_AGORA_ENCRYPTION_SALT=your_agora_encryption_salt

# Expo Configuration (for push notifications)
# Get your project ID from: https://expo.dev/accounts/[your-account]/projects/[your-project]
# Or from: eas project:info (if using EAS)
# Format: UUID (e.g., 12345678-1234-1234-1234-123456789abc)
# Alternatively, add it to app.json under extra.eas.projectId
EXPO_PUBLIC_PROJECT_ID=your_expo_project_id

